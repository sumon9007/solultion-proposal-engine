# Solution Proposal Engine — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Company Identity ────────────────────────────────────────────────────────
COMPANY_NAME="Your Company Name"
COMPANY_WEBSITE="https://yourcompany.com"
COMPANY_EMAIL="proposals@yourcompany.com"
COMPANY_PHONE="+44 20 0000 0000"
COMPANY_ADDRESS="123 Business Street, London, EC1A 1AA"

# ─── Proposal Defaults ───────────────────────────────────────────────────────
DEFAULT_CURRENCY="GBP"
DEFAULT_PAYMENT_TERMS="30 days net"
DEFAULT_PROPOSAL_VALIDITY_DAYS=30
DEFAULT_AUTHOR="Senior Solutions Architect"

# ─── Export Settings ─────────────────────────────────────────────────────────
EXPORT_OUTPUT_DIR="output/exports"
HTML_TEMPLATE="assets/templates/proposal-template.html"
CSS_STYLESHEET="assets/templates/proposal-style.css"
INCLUDE_COVER_PAGE=true

# ─── Brand Defaults ──────────────────────────────────────────────────────────
BRAND_PRIMARY_COLOUR="#0B5FFF"
BRAND_SECONDARY_COLOUR="#0F172A"
BRAND_ACCENT_COLOUR="#14B8A6"
BRAND_FONT_HEADINGS="Aptos Display"
BRAND_FONT_BODY="Aptos"

# ─── Logo (optional) ─────────────────────────────────────────────────────────
# Path to your company logo (PNG or SVG recommended).
# Relative paths are resolved from the project root.
# If set, the logo is embedded (base64) in HTML and PDF exports.
# If unset, the company name text is used in the header instead.
# LOGO_PATH="assets/logo/company-logo.png"
