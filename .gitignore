# Environment
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Output — track folder structure but not generated content
output/drafts/**/*.md
output/approved/**/*.md
output/exports/**/*.html
output/exports/**/*.pdf
output/packages/**/*.json
!output/**/.gitkeep

# Input — track structure and register, not raw customer files or working extracts
input/raw/**/*
input/working/**/*
input/archive/**/*
input/normalized/**/*.md
!input/**/.gitkeep
!input/README.md
!input/source-register.md

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temp
*.tmp
*.bak
